{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/proxy/(.*)", "dest": "/api/index.js" },
    { "src": "/piped/(.*)", "dest": "/api/index.js" },
    { "src": "/api/v2/video", "dest": "/api/index.js" },
    { "src": "/stats", "dest": "/api/index.js" },
    { "src": "/fake-views", "dest": "/api/index.js" },
    { "src": "/Tools/Science/proxy/(.*)", "dest": "/api/index.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  }
}
